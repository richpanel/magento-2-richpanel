<?xml version="1.0" encoding="UTF-8"?>
<!--
/**
 * Register global events
 *
 * @author Shubhanshu Chouhan <shubhanshu@richpanel.com>
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="sales_order_save_after">
        <observer name="richpanel_event_order" instance="Richpanel\Analytics\Observer\Order"/>
    </event>
    <event name="sales_order_shipment_save_after">
        <observer name="richpanel_event_shipment" instance="Richpanel\Analytics\Observer\Shipment"/>
    </event>

    <event name="sales_model_service_quote_submit_success">
        <observer name="richpanel_event_order_create" instance="Richpanel\Analytics\Observer\Order"/>
    </event>
    <event name="order_cancel_after">
        <observer name="richpanel_event_order_cancel" instance="Richpanel\Analytics\Observer\Order"/>
    </event>
</config>
