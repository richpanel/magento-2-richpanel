<?xml version="1.0"?>
<!--
/**
 * Store configurations for Richpanel extension
 *
 * @author Shubhanshu Chouhan <shubhanshu@richpanel.com>
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <!-- Add new Tab -->
        <tab id="richpanel" translate="label" sortOrder="300">
            <label>Richpanel</label>
        </tab>
        <section id="richpanel_analytics" translate="label" type="text" sortOrder="140" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Richpanel Helpdesk</label>
            <tab>richpanel</tab>
            <!-- resource tag name which we have to defined in the acl.xml -->
            <resource>Richpanel_Analytics::configuration</resource>
            <group id="general" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Configuration</label>
                <comment>
                    <![CDATA[
                    <div id="richpanel-info">
                        <div class="richpanel-logo"></div>
                        <div class="text">
                            This module was developed by <a href="http://richpanel.com" target="_blank">Richpanel</a><br />
                            If you encounter any issues, let us know at <a href="mailto:support@richpanel.com">support@richpanel.com</a>. We'll be happy to assist you!
                            <br/><b>Select a store view from top left to sync orders.</b>
                        </div>
                    </div>
                    <div style="clear:both;"></div>
                    ]]>
                </comment>
                <field id="enable" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="api_key" sortOrder="20" type="text" translate="label" showInDefault="1" showInWebsite="1" showInStore="1">
                    <depends><field id="enable">1</field></depends>
                    <label>API Token</label>
                    <backend_model>Richpanel\Analytics\Model\Trimmed</backend_model>
                </field>
                <field id="api_secret" sortOrder="30" type="text" translate="label" showInDefault="1" showInWebsite="1" showInStore="1">
                    <depends><field id="enable">1</field></depends>
                    <label>API Secret</label>
                    <backend_model>Richpanel\Analytics\Model\Trimmed</backend_model>
                </field>
                <field id="rp_duration" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <!-- <depends><field id="import">1</field></depends> -->
                    <label>Sync Duration</label>
                    <source_model>Richpanel\Analytics\Model\Config\Source\ListMode</source_model>
                    <config_path>richpanel_analytics/general/rp_duration</config_path>
                </field>
                <field id="import" translate="label" type="button" sortOrder="50" showInDefault="0" showInWebsite="0" showInStore="1">
                    <label>Import Orders</label>
                    <button_label><![CDATA[Import orders]]></button_label>
                    <button_url>
                        <![CDATA[richpanel/analytics/import]]>
                    </button_url>
                    <frontend_model>Richpanel\Analytics\Block\System\Config\Button\Import</frontend_model>
                    <comment>First set API token and secret before import orders</comment>
                </field>
            </group>
        </section>
    </system>
</config>
